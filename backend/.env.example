# Backend .env variables (for Render deployment and local development)

# Render deployment:
# DATABASE_URL: Neon PostgreSQL connection string (postgresql://user:***@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require)
# REDIS_URL: Upstash Redis URL
# CLERK_JWKS_URL: Clerk production JWKS URL (https://<your-clerk-prod-domain>/.well-known/jwks.json)
# CLERK_SECRET_KEY: Clerk production secret key (sk_live_...)
# CORS_ORIGINS: Comma-separated list of allowed origins (e.g., https://<your-vercel-url>.vercel.app)

# Local development (example values):
# DATABASE_URL=postgresql://user:password@localhost:5432/pod_manufacturing_db
# REDIS_URL=redis://localhost:6379/0
# CLERK_JWKS_URL=https://api.clerk.com/.well-known/jwks.json # Example for local testing with Clerk development keys
# CLERK_SECRET_KEY=sk_test_yourclerksecret
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000
