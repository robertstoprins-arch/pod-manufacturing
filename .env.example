# Copy this to .env and fill in your values
# For local development with Docker Compose, the defaults below work as-is

DATABASE_URL=postgresql://pod:pod_secret@localhost:5432/pod_mfg
REDIS_URL=redis://localhost:6379/0

# Object storage (Hetzner S3-compatible) — leave blank for local dev
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Auth (Clerk)
# Get these from https://dashboard.clerk.com → your app → API Keys
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
# JWKS URL: Dashboard → API Keys → "Show JWT public key" → copy the JWKS URL
# Format: https://<instance>.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URL=

# CORS — comma-separated list of allowed frontend origins
# Local dev default is set in main.py; set this in production (Render env var)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Frontend (Vite) — set in .env.local for local dev, or Vercel env vars for production
# VITE_API_URL=http://localhost:8000
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
